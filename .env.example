# =============================================
# GLOBAL WORKSPACE - Environment Variables Example
# =============================================

# ----- Server Configuration -----
PORT=5000
JWT_SECRET=your_super_strong_random_jwt_secret_hex_string
FRONTEND_URL=http://localhost:3000

# ----- Database (MongoDB) -----
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/traveldb?retryWrites=true&w=majority

# ----- Third-Party APIs -----
WEATHER_API_KEY=your_openweathermap_api_key
FLIGHT_API_KEY=your_flight_api_key
GOOGLE_CLIENT_ID=your_google_client_id
OPENTRIPMAP_BASE_URL=https://api.opentripmap.com/0.1
OPENTRIPMAP_API_KEY=enter_your_api_key
OPENTRIPMAP_LANG=en

# ----- Active Email Service (Gmail SMTP) -----
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=your-gmail-address@gmail.com
EMAIL_FROM_NAME=PackGo

# ----- Alternative Service (Uncomment to use Resend) -----
# EMAIL_SERVICE=resend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=resend
# EMAIL_PASS=your_resend_smtp_or_api_key
# EMAIL_FROM=noreply@your-domain.com
# EMAIL_FROM_NAME=PackGo

# Backward-compatible SMTP aliases
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-gmail-address@gmail.com
# SMTP_PASS=your_gmail_app_password
# FROM_EMAIL=your-gmail-address@gmail.com
# FROM_NAME=PackGo

# Client Environment Variables (If any)
# REACT_APP_API_URL=http://localhost:5000/api