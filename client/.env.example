# =============================================
# CLIENT - Environment Variables Example
# =============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ----- API Configuration -----
# Local development URL
REACT_APP_API_URL=http://localhost:5000/api

# Production URL (uncomment when deploying)
# REACT_APP_API_URL=https://your-backend-url.onrender.com/api

# ----- Build Settings -----
# Disable source maps in production build (recommended)
GENERATE_SOURCEMAP=false

#for google login
GOOGLE_CLIENT_ID=xxxxxxxxxxx.apps.googleusercontent.com

# ----- Currency Conversion (Frankfurter - no API key required) -----
# Free, open-source exchange rate API. Override only if self-hosting Frankfurter.
REACT_APP_FRANKFURTER_API_URL=https://api.frankfurter.dev/v1
